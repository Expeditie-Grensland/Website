{
  "name": "expeditiegrensland-website",
  "version": "1.0.0",
  "private": true,
  "description": "Expeditie Grensland Website",
  "license": "MIT",
  "homepage": "https://expeditiegrensland.nl",
  "repository": "github:Expeditie-Grensland/Website",
  "bugs": "https://github.com/Expeditie-Grensland/Website/issues",
  "contributors": [
    {
      "name": "Martijn Atema",
      "email": "martijn@atema.one"
    },
    {
      "name": "Maurice Meedendorp",
      "email": "mauricemeedendorp@gmail.com"
    }
  ],
  "files": [
    "remix.config.js",
    "build/",
    "public/"
  ],
  "scripts": {
    "check": "concurrently -g -c magenta -n 'c:' 'npm:check:*'",
    "check:format": "prettier --check .",
    "check:eslint": "eslint .",
    "format": "prettier --write .",
    "dev": "concurrently -c magenta -n 'd:' 'npm:dev:*'",
    "dev:app": "remix dev",
    "dev:db": "watch 'prisma generate' db/",
    "dev:protobufs": "watch 'npx pbjs -t static-module -w es6 -o app/generated/protobufs/index.js protobufs/**/*.proto && npx pbts -o app/generated/protobufs/index.d.ts app/generated/protobufs/index.js' protobufs/",
    "dev:styles": "postcss --watch --verbose --env development -d app/generated/styles/ styles/**/*.css",
    "clean": "rimraf .cache/ build/ public/build/ app/generated/",
    "build": "concurrently -c magenta -n 'b:' 'npm:build:*(!app)' && concurrently -c magenta -n 'b:app' 'npm:build:app'",
    "build:app": "remix build",
    "build:db": "prisma generate",
    "build:protobufs": "npx pbjs -t static-module -w es6 -o app/generated/protobufs/index.js protobufs/**/*.proto && npx pbts -o app/generated/protobufs/index.d.ts app/generated/protobufs/index.js",
    "build:styles": "postcss --verbose --env production -d app/generated/styles/ styles/**/*.css",
    "start": "remix-serve build"
  },
  "dependencies": {
    "@prisma/client": "^3.14.0",
    "@remix-run/node": "^1.4.3",
    "@remix-run/react": "^1.4.3",
    "@remix-run/serve": "^1.4.3",
    "date-fns": "^2.28.0",
    "date-fns-tz": "^1.3.4",
    "encoding": "^0.1.13",
    "hls.js": "^1.1.5",
    "ldapjs": "^2.3.2",
    "mapbox-gl": "^2.8.2",
    "marked-react": "^1.1.1",
    "nanoid": "^3.3.4",
    "protobufjs": "^6.11.2",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "redis": "^4.1.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.4.3",
    "@remix-run/eslint-config": "^1.4.3",
    "@tailwindcss/forms": "^0.5.1",
    "@types/geojson": "^7946.0.8",
    "@types/ldapjs": "^2.2.2",
    "@types/mapbox-gl": "^2.7.1",
    "@types/react": "^18.0.9",
    "@types/react-dom": "^18.0.4",
    "@typescript-eslint/eslint-plugin": "^5.23.0",
    "@typescript-eslint/parser": "^5.23.0",
    "autoprefixer": "^10.4.7",
    "concurrently": "^7.2.0",
    "cssnano": "^5.1.7",
    "eslint": "^8.15.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "postcss": "^8.4.13",
    "postcss-cli": "^9.1.0",
    "prettier": "^2.6.2",
    "prisma": "^3.14.0",
    "rimraf": "^3.0.2",
    "tailwindcss": "^3.0.24",
    "typescript": "^4.6.4",
    "watch": "^1.0.2"
  },
  "engines": {
    "node": ">=14"
  },
  "sideEffects": false,
  "prisma": {
    "schema": "db/schema.prisma"
  }
}
