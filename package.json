{
  "name": "expeditiegrensland-website",
  "version": "1.0.0",
  "private": true,
  "description": "Expeditie Grensland Website",
  "license": "MIT",
  "homepage": "https://expeditiegrensland.nl",
  "repository": "github:Expeditie-Grensland/Website",
  "bugs": "https://github.com/Expeditie-Grensland/Website/issues",
  "contributors": [
    {
      "name": "Martijn Atema",
      "email": "martijn@atema.one"
    },
    {
      "name": "Maurice Meedendorp",
      "email": "mauricemeedendorp@gmail.com"
    }
  ],
  "files": [
    "remix.config.js",
    "build/",
    "public/"
  ],
  "scripts": {
    "check": "concurrently -g -c magenta -n 'c:' 'npm:check:*'",
    "check:format": "prettier --check .",
    "check:eslint": "eslint .",
    "format": "prettier --write .",
    "dev": "concurrently -c magenta -n 'd:' 'npm:dev:*'",
    "dev:app": "remix dev",
    "dev:db": "watch 'prisma generate' db/",
    "dev:styles": "postcss --watch --verbose --env development -d app/generated/styles/ styles/**/*.css",
    "clean": "rimraf .cache/ build/ public/build/ app/generated/",
    "build": "concurrently -c magenta -n 'b:' 'npm:build:*(!app)' && concurrently -c magenta -n 'b:app' 'npm:build:app'",
    "build:app": "remix build",
    "build:db": "prisma generate",
    "build:styles": "postcss --verbose --env production -d app/generated/styles/ styles/**/*.css",
    "serve": "remix-serve build"
  },
  "dependencies": {
    "@prisma/client": "^3.13.0",
    "@remix-run/node": "^1.4.3",
    "@remix-run/react": "^1.4.3",
    "@remix-run/serve": "^1.4.3",
    "encoding": "^0.1.13",
    "hls.js": "^1.1.5",
    "ldapjs": "^2.3.2",
    "nanoid": "^3.3.3",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "redis": "^4.0.6"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.4.3",
    "@remix-run/eslint-config": "^1.4.3",
    "@types/ldapjs": "^2.2.2",
    "@types/react": "^18.0.8",
    "@types/react-dom": "^18.0.3",
    "@typescript-eslint/eslint-plugin": "^5.21.0",
    "@typescript-eslint/parser": "^5.21.0",
    "autoprefixer": "^10.4.6",
    "concurrently": "^7.1.0",
    "cssnano": "^5.1.7",
    "eslint": "^8.14.0",
    "eslint-config-prettier": "^8.5.0",
    "postcss": "^8.4.13",
    "postcss-cli": "^9.1.0",
    "prettier": "^2.6.2",
    "prisma": "^3.13.0",
    "rimraf": "^3.0.2",
    "tailwindcss": "^3.0.24",
    "typescript": "^4.6.4",
    "watch": "^1.0.2"
  },
  "engines": {
    "node": ">=14"
  },
  "sideEffects": false,
  "prisma": {
    "schema": "db/schema.prisma"
  }
}
